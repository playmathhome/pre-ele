---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const allUnits = await getCollection('math-units');
  return allUnits.map(unit => ({
    params: { slug: unit.id }, props: { unit },
  }));
}

const { unit } = Astro.props;
const { Content } = await render(unit);
---

<BaseLayout title={unit.id}>
  <main class="max-w-7xl mx-auto px-4 py-12">
    <a href="/" class="inline-block mb-8 text-xl font-bold text-gray-500 hover:text-gray-800 transition-colors bg-white px-8 py-3 rounded-full shadow-md">
      ← 돌아가기
    </a>
    
    <article class="prose-custom bg-white p-6 md:p-14 lg:p-20 rounded-[5rem] shadow-2xl border-t-[2rem] border-[#D1FAE5]">
      <div class="mb-12 text-center">
        <span class="text-7xl mb-4 block">📚</span>
      </div>
      <div class="w-full">
        <Content />
      </div>
    </article>
  </main>
</BaseLayout>
