---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact Us">
  <div class="max-w-2xl mx-auto py-12 px-4 sm:px-6 lg:px-8">
    <div class="bg-white p-8 rounded-xl shadow-sm border border-gray-100">
      <h1 class="text-3xl font-bold text-gray-900 mb-6">Contact Us</h1>
      <p class="text-gray-600 mb-8">문의 사항이 있으시면 아래 양식을 통해 연락해 주세요.</p>

      <!-- 성공/에러 메시지 영역 -->
      <div data-fs-success class="hidden mb-6 p-4 bg-green-50 border border-green-200 text-green-700 rounded-lg">
        성공적으로 전송되었습니다! 곧 답변 드리겠습니다.
      </div>
      <div data-fs-error class="hidden mb-6 p-4 bg-red-50 border border-red-200 text-red-700 rounded-lg">
        전송 중 오류가 발생했습니다. 다시 시도해 주세요.
      </div>

      <form id="contact-form" class="space-y-6">
        <div>
          <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email</label>
          <input 
            type="email" 
            id="email" 
            name="email" 
            required 
            data-fs-field
            placeholder="example@email.com"
            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors"
          />
          <span data-fs-error="email" class="text-sm text-red-600 mt-1 block"></span>
        </div>

        <div>
          <label for="message" class="block text-sm font-medium text-gray-700 mb-1">Message</label>
          <textarea 
            id="message" 
            name="message" 
            required 
            rows="4"
            data-fs-field
            placeholder="문의하실 내용을 입력해 주세요."
            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors"
          ></textarea>
          <span data-fs-error="message" class="text-sm text-red-600 mt-1 block"></span>
        </div>

        <button 
          type="submit" 
          data-fs-submit-btn
          class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 px-6 rounded-lg shadow-md transition-all disabled:opacity-50 disabled:cursor-not-allowed"
        >
          Send Message
        </button>
      </form>
    </div>
  </div>
</BaseLayout>

<script>
  import { initForm } from '@formspree/ajax';
  
  // 폼 초기화
  initForm({ 
    formElement: '#contact-form', 
    formId: 'mbdpwqpl',
    onSuccess: () => {
      // 추가적인 성공 로직이 필요한 경우 여기에 작성
      const successMsg = document.querySelector('[data-fs-success]');
      if (successMsg) successMsg.classList.remove('hidden');
      const form = document.getElementById('contact-form');
      if (form) form.classList.add('hidden');
    }
  });
</script>
