---
import '../styles/global.css';
const { title } = Astro.props;
---

<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title || '우리아이 창의수학'}</title>
    <link rel="stylesheet" as="style" crossorigin href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard.css" />
    
    <!-- 구글 애드센스 승인 후 사용하는 스크립트 위치 (아래 주석 해제 후 ca-pub-xxx 입력) -->
    <!-- <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-XXXXXXXXXXXXXXXX" crossorigin="anonymous"></script> -->
  </head>
  <body class="bg-[#FFFBEB] font-[Pretendard] text-gray-800 text-lg flex flex-col min-h-screen">
    <!-- GNB Navigation Bar -->
    <header class="bg-white/80 backdrop-blur-md sticky top-0 z-50 border-b border-gray-100 shadow-sm transition-all duration-300">
      <div class="max-w-4xl mx-auto px-6 h-16 flex items-center justify-between">
        <a href="/" class="text-xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-[#10B981] to-[#3B82F6] hover:opacity-80 transition-opacity">🌈 창의 수학 홈스쿨링</a>
        <nav class="flex gap-6">
          <a href="/about" class="text-lg font-bold text-gray-600 hover:text-[#10B981] transition-colors">사이트 소개</a>
          <a href="/contact" class="text-lg font-bold text-gray-600 hover:text-[#10B981] transition-colors">문의하기</a>
        </nav>
      </div>
    </header>

    <!-- Main Content -->
    <main class="flex-grow">
      <slot />
    </main>

    <!-- Global Footer -->
    <footer class="bg-white mt-16 border-t border-gray-100 py-10">
      <div class="max-w-4xl mx-auto px-6 flex flex-col md:flex-row justify-between items-center gap-6 text-sm text-gray-500">
        <div class="text-center md:text-left">
          <p class="font-bold text-gray-700 mb-1">창의 수학 홈스쿨링</p>
          <p>&copy; 2026. All rights reserved.</p>
        </div>
        <div class="flex gap-6 font-medium">
          <a href="/privacy" class="hover:text-gray-800 underline underline-offset-4 transition-colors">개인정보처리방침</a>
          <a href="/terms" class="hover:text-gray-800 underline underline-offset-4 transition-colors">이용약관</a>
          <a href="/contact" class="hover:text-gray-800 underline underline-offset-4 transition-colors text-gray-400">문의하기</a>
        </div>
      </div>
    </footer>
  </body>
</html>

<style is:global>
</style>
